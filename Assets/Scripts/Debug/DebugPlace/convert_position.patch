+    /// <summary>
+    /// 位置を変換する（X軸800.0f→Z軸20.0f、Y軸300.0f→X軸7.0f）
+    /// </summary>
+    private Vector3 ConvertPosition(Vector3 localPosition)
+    {
+        // X軸800.0fをZ軸20.0fに変換
+        float convertedZ = (localPosition.x / 800.0f) * 20.0f;
+        
+        // Y軸300.0fをX軸7.0fに変換
+        float convertedX = (localPosition.y / 300.0f) * 7.0f;
+        
+        // Z軸はそのまま
+        float convertedY = localPosition.z;
+        
+        return new Vector3(convertedX, convertedY, convertedZ);
+    }
